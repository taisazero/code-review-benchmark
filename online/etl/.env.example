# Database URL - sqlite for dev, postgresql for production
DATABASE_URL=sqlite:///pr_review.db

# GitHub personal access token
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Cloud project for BigQuery billing
GCP_PROJECT=my-gcp-project

# GCP Cloud SQL instance (for cloud-sql-proxy)
GCP_SQL_INSTANCE=your-project:region:instance-name

# LLM API settings (OpenAI-compatible endpoint)
MARTIAN_BASE_URL=https://api.example.com/v1
MARTIAN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
MARTIAN_MODEL_NAME=gpt-4o

# Worker identification (for distributed locking)
WORKER_ID=worker-1

# Lock timeout in minutes (stale locks older than this are reclaimed)
LOCK_TIMEOUT_MINUTES=30

# PR size limits — PRs exceeding these are skipped during enrichment
MAX_PR_COMMITS=50
MAX_PR_CHANGED_LINES=2000
